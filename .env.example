# EmailJS — required for the contact form to actually send mail.
# Sign up at https://www.emailjs.com → create a Service + Template, then paste:
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Fallback inbox the form mails to (also used in Contact "Email" tile).
# Defaults to the value in src/constants/index.js → profile.email if blank.
VITE_CONTACT_EMAIL=awahabpirzada@gmail.com
